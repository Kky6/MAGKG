        "has_time",
        "genetically_related_to"
      ],
      "as_tail": [
        "hosted_in",
        "part_of",
        "sampled_from",
        "derived_from",
        "controlled_by",
        "caused_by",
        "genetically_related_to"
      ]
    },
    "StratigraphicUnit": {
      "as_head": [
        "has_value",
