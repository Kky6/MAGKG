        "part_of",
        "has_time"
      ],
      "as_tail": [
        "hosted_in",
        "part_of",
        "sampled_from",
        "controlled_by",
        "derived_from",
        "caused_by"
      ]
    },
    "GeologicalTime": {
      "as_head": [
        "has_value"
      ],
      "as_tail": [
        "has_time"
      ]
    },
    "Sample": {
      "as_head": [
        "has_value",
        "located_in",
        "sampled_from",
        "analyzed_by"
      ],
      "as_tail": []
    },
    "Method": {
      "as_head": [],
      "as_tail": [
        "analyzed_by"
      ]
    },
    "Instrument": {
      "as_head": [],
      "as_tail": [
        "analyzed_by"
      ]
    },
    "Value": {
      "as_head": [
        "analyzed_by"
      ],
      "as_tail": [
        "has_value"
      ]
    },
    "Tectonism": {
      "as_head": [
        "has_value",
        "has_time",
        "part_of",
        "genetically_related_to"
      ],
      "as_tail": [
        "located_in",
        "part_of",
        "controlled_by",
        "genetically_related_to"
      ]
    }
  }
}